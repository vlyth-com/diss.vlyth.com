---
import card from "../data/card.json";
import Icon from "../components/Icon.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{card.name}</title>
    </head>
    <body>
        <div class="card">
            <div class="card-inner">
                <div class="card-front">
                    <div class="front-content">
                        <div class="left">
                            <h1 class="name">{card.name}</h1>
                            <p class="role">{card.role}</p>
                            <p class="quip">{card.quip}</p>
                        </div>
                        <div class="separator"></div>
                        <div class="right">
                            {
                                card.links.map((link) => (
                                    <a
                                        href={link.url}
                                        target={
                                            link.url.startsWith("mailto")
                                                ? undefined
                                                : "_blank"
                                        }
                                        class="link"
                                    >
                                        <Icon icon={link.icon} url={link.url} />
                                        <span>{link.label}</span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                    <button class="flip-btn" aria-label="Flip card">
                        <Icon icon="lucide:refresh-cw" />
                    </button>
                    <div class="flip-hint">
                        <span class="flip-hint-text">flip for more info</span>
                        <span class="flip-hint-arrow">→</span>
                    </div>
                </div>
                <div class="card-back">
                    <div class="back-content">
                        <p>{card.back}</p>
                    </div>
                    <button class="flip-btn" aria-label="Flip card back">
                        <Icon icon="lucide:refresh-cw" />
                    </button>
                </div>
                <div class="mouse-light"></div>
            </div>
        </div>
    </body>
</html>

<style is:global>
    /* ── Reset ── */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* ── Page ── */
    html,
    body {
        width: 100%;
        height: 100%;
        background: #0a0a0a;
        display: flex;
        justify-content: center;
        align-items: center;
        user-select: none;
        -webkit-user-select: none;
    }

    /* ── Card shell: size, perspective, entrance ── */
    .card {
        width: min(420px, calc(100vw - 4rem));
        aspect-ratio: 7 / 4;
        perspective: 800px;
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        animation: swipeUp 0.8s cubic-bezier(0.16, 1.3, 0.3, 1) both;
    }

    /* ── Flip + tilt wrapper ── */
    .card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
    }

    /* ── Faces ── */
    .card-front,
    .card-back {
        position: absolute;
        inset: 0;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        overflow: hidden;
    }

    .card-back {
        display: none;
    }

    /* ── Mouse light: two sources, card hover only ── */
    .mouse-light {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .card-inner:hover .mouse-light {
        opacity: 1;
    }

    .mouse-light::before,
    .mouse-light::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 8px;
        pointer-events: none;
    }

    /* Direct: follows cursor */
    .mouse-light::before {
        background: radial-gradient(
            circle at var(--mlx, 50%) var(--mly, 50%),
            rgba(255, 255, 255, 0.015) 0%,
            rgba(255, 255, 255, 0.005) 30%,
            transparent 60%
        );
    }

    /* Mirrored: opposite side of cursor */
    .mouse-light::after {
        background: radial-gradient(
            circle at var(--mrx, 50%) var(--mry, 50%),
            rgba(255, 255, 255, 0.012) 0%,
            rgba(255, 255, 255, 0.004) 30%,
            transparent 60%
        );
    }

    /* ── Light reflections (front face only) ── */
    .card-front::before,
    .card-front::before,
    .card-front::after,
    .card-back::before,
    .card-back::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 8px;
        clip-path: inset(0 round 8px);
        pointer-events: none;
    }

    .card-front::before,
    .card-back::before {
        background: radial-gradient(
            ellipse 180% 120% at var(--lx1, 30%) var(--ly1, 30%),
            rgba(255, 255, 255, 0.05) 0%,
            rgba(255, 255, 255, 0.025) 25%,
            rgba(255, 255, 255, 0.01) 50%,
            transparent 75%
        );
    }

    .card-front::after,
    .card-back::after {
        background: radial-gradient(
            ellipse 160% 140% at var(--lx2, 70%) var(--ly2, 70%),
            rgba(255, 255, 255, 0.04) 0%,
            rgba(255, 255, 255, 0.02) 25%,
            rgba(255, 255, 255, 0.008) 50%,
            transparent 75%
        );
    }

    /* ── Front layout ── */
    .front-content {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
        height: 100%;
    }

    .separator {
        position: absolute;
        top: 12%;
        bottom: 12%;
        left: 50%;
        width: 1px;
        background: #2a2a2a;
        transform: translateX(-50%);
        pointer-events: none;
    }

    .left {
        flex: 1;
        padding: 0 24px;
        user-select: text;
        -webkit-user-select: text;
    }

    .name {
        font-size: 1.35rem;
        font-weight: 700;
        color: #e8e8e8;
        letter-spacing: -0.02em;
    }

    .role {
        font-size: 0.7rem;
        color: #888;
        margin-top: 4px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .quip {
        font-size: 0.65rem;
        color: #555;
        margin-top: 10px;
        font-style: italic;
    }

    .right {
        flex: 1;
        padding: 0 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        user-select: text;
        -webkit-user-select: text;
    }

    .link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #666;
        text-decoration: none;
        font-size: 0.65rem;
        letter-spacing: 0.02em;
        transition: color 0.2s;
    }

    .link:hover {
        color: #e8e8e8;
    }

    .link svg {
        flex-shrink: 0;
    }

    /* ── Back layout ── */
    .back-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        padding: 24px 32px;
        z-index: 1;
    }

    .back-content p {
        font-size: 0.7rem;
        color: #888;
        line-height: 1.6;
        text-align: center;
        user-select: text;
        -webkit-user-select: text;
    }

    /* ── Flip button ── */
    .flip-btn {
        position: absolute;
        bottom: 10px;
        right: 12px;
        z-index: 10;
        background: none;
        border: none;
        color: #444;
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }

    .flip-btn:hover {
        color: #e8e8e8;
    }

    /* ── Flip hint ── */
    .flip-hint {
        position: absolute;
        bottom: 12px;
        right: 44px;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 6px;
        color: #555;
        font-size: 0.72rem;
        letter-spacing: 0.03em;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .flip-hint.visible {
        opacity: 1;
        animation: hintPulse 2s ease-in-out infinite;
    }

    .flip-hint.visible .flip-hint-arrow {
        animation: hintBounce 1.5s ease-in-out infinite;
    }

    .flip-hint.hidden {
        opacity: 0;
    }

    .flip-hint-text {
        white-space: nowrap;
    }

    .flip-hint-arrow {
        font-size: 0.85rem;
    }

    @keyframes hintPulse {
        0%,
        100% {
            color: #555;
        }
        50% {
            color: #888;
        }
    }

    @keyframes hintBounce {
        0%,
        100% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(3px);
        }
    }

    /* ── Entrance ── */
    @keyframes swipeUp {
        from {
            transform: translateY(100vh) rotate(90deg);
            opacity: 0;
        }
        to {
            transform: translateY(0) rotate(0deg);
            opacity: 1;
        }
    }

    @keyframes flipOut {
        from {
            transform: rotateY(0deg);
        }
        to {
            transform: rotateY(90deg);
        }
    }

    @keyframes flipIn {
        from {
            transform: rotateY(-90deg);
        }
        to {
            transform: rotateY(0deg);
        }
    }
</style>

<script>
    const card = document.querySelector(".card") as HTMLElement;
    const cardInner = document.querySelector(".card-inner") as HTMLElement;
    const cardFront = document.querySelector(".card-front") as HTMLElement;
    const cardBack = document.querySelector(".card-back") as HTMLElement;
    const body = document.body;

    // ── State ──
    let flipped = false;
    let flipTransitioning = false;
    let isDragging = false;
    let startX = 0;
    let startY = 0;
    let tiltX = 0;
    let tiltY = 0;
    let velocityX = 0;
    let velocityY = 0;
    let animating = false;

    // ── Mouse light state (independent of tilt) ──
    let mouseLightX = 0;
    let mouseLightY = 0;
    let mouseLightTargetX = 0;
    let mouseLightTargetY = 0;
    let mouseLightAnimating = false;

    const MAX_TILT = 25;
    const SENSITIVITY = 0.15;
    const STIFFNESS = 0.12;
    const DAMPING = 0.75;

    // ── Entrance animation cleanup ──
    card.addEventListener("animationend", () => {
        card.style.animation = "none";
    });

    // ── Apply lights from tilt ──
    function applyLights(rx: number, ry: number) {
        const lx1 = 30 - ry * 1.2;
        const ly1 = 30 + rx * 1.2;
        cardInner.style.setProperty("--lx1", `${lx1}%`);
        cardInner.style.setProperty("--ly1", `${ly1}%`);

        const lx2 = 70 + ry * 0.8;
        const ly2 = 70 - rx * 0.8;
        cardInner.style.setProperty("--lx2", `${lx2}%`);
        cardInner.style.setProperty("--ly2", `${ly2}%`);
    }

    // ── Apply transform + lights ──
    function applyTransform(rx: number, ry: number) {
        cardInner.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;
        applyLights(rx, ry);
    }

    // ── Spring system ──
    function springTick() {
        velocityX = (velocityX + (0 - tiltX) * STIFFNESS) * DAMPING;
        velocityY = (velocityY + (0 - tiltY) * STIFFNESS) * DAMPING;
        tiltX += velocityX;
        tiltY += velocityY;

        applyTransform(tiltX, tiltY);

        if (
            Math.abs(tiltX) < 0.01 &&
            Math.abs(tiltY) < 0.01 &&
            Math.abs(velocityX) < 0.01 &&
            Math.abs(velocityY) < 0.01
        ) {
            tiltX = 0;
            tiltY = 0;
            velocityX = 0;
            velocityY = 0;
            applyTransform(0, 0);
            animating = false;
            return;
        }

        requestAnimationFrame(springTick);
    }

    function startSpring() {
        velocityX = 0;
        velocityY = 0;
        animating = true;
        requestAnimationFrame(springTick);
    }

    // ── Elastic clamp ──
    function elasticClamp(value: number, max: number): number {
        const sign = Math.sign(value);
        const abs = Math.abs(value);
        if (abs <= max) return value;
        return sign * (max + (abs - max) * 0.15);
    }

    // ── Flip light animation ──
    let flipLightRaf = 0;
    let flipLightStart = 0;

    function flipLightTick(phase: "out" | "in") {
        return (timestamp: number) => {
            if (!flipLightStart) flipLightStart = timestamp;
            const elapsed = timestamp - flipLightStart;
            const progress = Math.min(elapsed / 300, 1);

            const effectiveRy =
                phase === "out"
                    ? tiltY + progress * 90
                    : tiltY - 90 + progress * 90;

            applyLights(tiltX, effectiveRy);

            if (progress < 1) {
                flipLightRaf = requestAnimationFrame(flipLightTick(phase));
            }
        };
    }

    // ── Flip hint ──
    const flipHint = document.querySelector(".flip-hint") as HTMLElement | null;
    let hintDismissed = false;
    let hintTimeout = setTimeout(() => {
        if (flipHint && !hintDismissed) flipHint.classList.add("visible");
    }, 10000);

    function dismissHint() {
        if (hintDismissed || !flipHint) return;
        hintDismissed = true;
        clearTimeout(hintTimeout);
        flipHint.classList.remove("visible");
        flipHint.classList.add("hidden");
        setTimeout(() => flipHint.remove(), 400);
    }

    // ── Flip ──
    function flipCard() {
        if (flipTransitioning) return;
        flipped = !flipped;
        flipTransitioning = true;
        mouseLight.style.opacity = "0";

        const outEl = flipped ? cardFront : cardBack;
        const inEl = flipped ? cardBack : cardFront;

        outEl.style.animation = "flipOut 0.3s ease-in forwards";

        // Animate lights during flip-out
        cancelAnimationFrame(flipLightRaf);
        flipLightStart = 0;
        flipLightRaf = requestAnimationFrame(flipLightTick("out"));

        setTimeout(() => {
            cancelAnimationFrame(flipLightRaf);
            outEl.style.display = "none";
            outEl.style.animation = "none";

            inEl.style.display = "block";
            inEl.style.animation = "flipIn 0.3s ease-out forwards";

            // Animate lights during flip-in
            flipLightStart = 0;
            flipLightRaf = requestAnimationFrame(flipLightTick("in"));
        }, 300);

        setTimeout(() => {
            cancelAnimationFrame(flipLightRaf);
            inEl.style.animation = "none";
            flipTransitioning = false;
            applyLights(tiltX, tiltY);
            mouseLight.style.opacity = "";
        }, 620);
    }

    document.querySelectorAll(".flip-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            dismissHint();
            flipCard();
        });
    });

    // ── Drag handlers ──
    function onStart(e: MouseEvent | TouchEvent) {
        if (card.contains(e.target as Node)) return;
        isDragging = true;
        animating = false;
        const point = "touches" in e ? e.touches[0] : e;
        startX = point.clientX;
        startY = point.clientY;
    }

    function onMove(e: MouseEvent | TouchEvent) {
        if (!isDragging) return;
        const point = "touches" in e ? e.touches[0] : e;
        const dx = point.clientX - startX;
        const dy = point.clientY - startY;

        tiltY = elasticClamp(dx * SENSITIVITY, MAX_TILT);
        tiltX = elasticClamp(-dy * SENSITIVITY, MAX_TILT);

        applyTransform(tiltX, tiltY);
    }

    function onEnd() {
        if (!isDragging) return;
        isDragging = false;
        startSpring();
    }

    // ── Mouse light: its own source, card hover only ──
    const mouseLight = document.querySelector(".mouse-light") as HTMLElement;

    function mouseLightTick() {
        mouseLightX += (mouseLightTargetX - mouseLightX) * 0.15;
        mouseLightY += (mouseLightTargetY - mouseLightY) * 0.15;

        const done =
            Math.abs(mouseLightX - mouseLightTargetX) < 0.01 &&
            Math.abs(mouseLightY - mouseLightTargetY) < 0.01;

        if (done) {
            mouseLightX = mouseLightTargetX;
            mouseLightY = mouseLightTargetY;
        }

        mouseLight.style.setProperty("--mlx", `${mouseLightX}%`);
        mouseLight.style.setProperty("--mly", `${mouseLightY}%`);
        mouseLight.style.setProperty("--mrx", `${100 - mouseLightX}%`);
        mouseLight.style.setProperty("--mry", `${100 - mouseLightY}%`);

        if (!done) {
            requestAnimationFrame(mouseLightTick);
        } else {
            mouseLightAnimating = false;
        }
    }

    function startMouseLightAnim() {
        if (!mouseLightAnimating) {
            mouseLightAnimating = true;
            requestAnimationFrame(mouseLightTick);
        }
    }

    card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const nx = (e.clientX - rect.left) / rect.width;
        const ny = (e.clientY - rect.top) / rect.height;
        mouseLightTargetX = nx * 100;
        mouseLightTargetY = ny * 100;
        startMouseLightAnim();
    });

    card.addEventListener("mouseleave", () => {
        mouseLightTargetX = 50;
        mouseLightTargetY = 50;
        startMouseLightAnim();
    });

    body.addEventListener("mousedown", onStart);
    body.addEventListener("mousemove", onMove);
    body.addEventListener("mouseup", onEnd);
    body.addEventListener("mouseleave", onEnd);

    body.addEventListener("touchstart", onStart, { passive: true });
    body.addEventListener("touchmove", onMove, { passive: true });
    body.addEventListener("touchend", onEnd);
</script>
