</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html,
    body {
        width: 100%;
        height: 100%;
        background: #0a0a0a;
        display: flex;
        justify-content: center;
        align-items: center;
        perspective: 800px;
    }

    .card {
        width: min(420px, calc(100vw - 4rem));
        aspect-ratio: 7 / 4;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        animation: swipeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
        will-change: transform;
        position: relative;
        overflow: hidden;
    }

    .card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 8px;
        background: radial-gradient(
            circle at var(--lx1, 30%) var(--ly1, 30%),
            rgba(255, 255, 255, 0.04) 0%,
            rgba(255, 255, 255, 0.01) 40%,
            transparent 70%
        );
        pointer-events: none;
    }

    .card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 8px;
        background: radial-gradient(
            circle at var(--lx2, 70%) var(--ly2, 70%),
            rgba(255, 255, 255, 0.03) 0%,
            rgba(255, 255, 255, 0.008) 40%,
            transparent 70%
        );
        pointer-events: none;
    }

    @keyframes swipeUp {
        from {
            transform: translateY(100vh) rotate(90deg);
            opacity: 0;
        }
        to {
            transform: translateY(0) rotate(0deg);
            opacity: 1;
        }
    }
</style>

<script>
    const card = document.querySelector(".card") as HTMLElement;
    const body = document.body;

    // Clear the entrance animation once it's done so JS can control transform
    card.addEventListener("animationend", () => {
        card.style.animation = "none";
        card.style.transform = "rotateX(0) rotateY(0)";
    });

    let isDragging = false;
    let startX = 0;
    let startY = 0;

    // Spring state
    let tiltX = 0;
    let tiltY = 0;
    let velocityX = 0;
    let velocityY = 0;
    let animating = false;

    const MAX_TILT = 25;
    const SENSITIVITY = 0.15;
    const STIFFNESS = 0.12;
    const DAMPING = 0.75;

    function elasticClamp(value: number, max: number): number {
        const sign = Math.sign(value);
        const abs = Math.abs(value);
        if (abs <= max) return value;
        return sign * (max + (abs - max) * 0.15);
    }

    function applyTilt(rx: number, ry: number) {
        card.style.transition = "none";
        card.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;

        // Two soft light sources shifting differently with tilt
        const lx1 = 30 - ry * 1.2;
        const ly1 = 30 + rx * 1.2;
        card.style.setProperty("--lx1", `${lx1}%`);
        card.style.setProperty("--ly1", `${ly1}%`);

        const lx2 = 70 + ry * 0.8;
        const ly2 = 70 - rx * 0.8;
        card.style.setProperty("--lx2", `${lx2}%`);
        card.style.setProperty("--ly2", `${ly2}%`);
    }

    function springTick() {
        velocityX = (velocityX + (0 - tiltX) * STIFFNESS) * DAMPING;
        velocityY = (velocityY + (0 - tiltY) * STIFFNESS) * DAMPING;
        tiltX += velocityX;
        tiltY += velocityY;

        applyTilt(tiltX, tiltY);

        if (
            Math.abs(tiltX) < 0.01 &&
            Math.abs(tiltY) < 0.01 &&
            Math.abs(velocityX) < 0.01 &&
            Math.abs(velocityY) < 0.01
        ) {
            tiltX = 0;
            tiltY = 0;
            velocityX = 0;
            velocityY = 0;
            applyTilt(0, 0);
            animating = false;
            return;
        }

        requestAnimationFrame(springTick);
    }

    function startSpring() {
        velocityX = 0;
        velocityY = 0;
        animating = true;
        requestAnimationFrame(springTick);
    }

    function onStart(e: MouseEvent | TouchEvent) {
        if (e.target === card) return;
        isDragging = true;
        animating = false;
        const point = "touches" in e ? e.touches[0] : e;
        startX = point.clientX;
        startY = point.clientY;
    }

    function onMove(e: MouseEvent | TouchEvent) {
        if (!isDragging) return;
        const point = "touches" in e ? e.touches[0] : e;
        const dx = point.clientX - startX;
        const dy = point.clientY - startY;

        tiltY = elasticClamp(dx * SENSITIVITY, MAX_TILT);
        tiltX = elasticClamp(-dy * SENSITIVITY, MAX_TILT);

        applyTilt(tiltX, tiltY);
    }

    function onEnd() {
        if (!isDragging) return;
        isDragging = false;
        startSpring();
    }

    body.addEventListener("mousedown", onStart);
    body.addEventListener("mousemove", onMove);
    body.addEventListener("mouseup", onEnd);
    body.addEventListener("mouseleave", onEnd);

    body.addEventListener("touchstart", onStart, { passive: true });
    body.addEventListener("touchmove", onMove, { passive: true });
    body.addEventListener("touchend", onEnd);
</script>
